{
  "openapi": "3.1.0",
  "info": {
    "title": "MindLaunch Capital Gateway API",
    "version": "0.1.0",
    "description": "Partner referral, capital interest, compliance routing, and dataroom API. This API does not move funds."
  },
  "paths": {
    "/api/health": {
      "get": { "summary": "Liveness check", "responses": { "200": { "description": "API is running" } } }
    },
    "/api/readiness": {
      "get": { "summary": "Database readiness check", "responses": { "200": { "description": "API can query Postgres" } } }
    },
    "/api/capital/state": {
      "get": { "summary": "Public Capital Gateway state", "responses": { "200": { "description": "Public projects, referral link, and non-private dataroom metadata" } } }
    },
    "/api/partner/capital-state": {
      "get": {
        "summary": "Partner-scoped dashboard and dataroom state",
        "parameters": [{ "name": "partnerCode", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Partner-scoped state" }, "401": { "description": "Partner token denied" } }
      }
    },
    "/api/admin/capital-state": {
      "get": {
        "summary": "Admin full state",
        "security": [{ "adminBearer": [] }],
        "responses": { "200": { "description": "Full admin state" }, "401": { "description": "Admin token denied" } }
      }
    },
    "/api/capital-interests": {
      "post": { "summary": "Submit indication of capital or partner interest", "responses": { "201": { "description": "Interest submitted for compliance review" } } }
    },
    "/api/wallet-connections": {
      "post": { "summary": "Record wallet connection attribution", "responses": { "201": { "description": "Wallet connection recorded" } } }
    },
    "/api/dataroom/access-requests": {
      "post": { "summary": "Request partner dataroom access", "responses": { "201": { "description": "Access request recorded" } } }
    },
    "/api/dataroom/events": {
      "post": { "summary": "Record dataroom view/download/request event", "responses": { "201": { "description": "Event recorded" }, "403": { "description": "Project access is not granted" } } }
    },
    "/api/dataroom/documents/{documentId}/access": {
      "get": {
        "summary": "Return a gated dataroom document storage URL and record view/download",
        "parameters": [
          { "name": "documentId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "partnerCode", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "event", "in": "query", "required": false, "schema": { "type": "string", "enum": ["view", "download"] } }
        ],
        "responses": { "200": { "description": "Document URL returned after access check" }, "403": { "description": "Project access is not granted" }, "404": { "description": "Document or storage URI not configured" } }
      }
    },
    "/api/admin/capital-interests/{interestId}/status": {
      "patch": { "summary": "Update lead status", "security": [{ "adminBearer": [] }], "responses": { "200": { "description": "Status updated" } } }
    },
    "/api/admin/compliance-reviews": {
      "post": { "summary": "Create or update a compliance review for a capital interest", "security": [{ "adminBearer": [] }], "responses": { "200": { "description": "Compliance review upserted" }, "404": { "description": "Capital interest not found" } } }
    },
    "/api/admin/approved-wallets": {
      "post": { "summary": "Approve or refresh an allowlisted wallet for Base USDC settlement", "security": [{ "adminBearer": [] }], "responses": { "200": { "description": "Wallet allowlist record updated" } } }
    },
    "/api/admin/settlement-intents": {
      "post": { "summary": "Create a disabled-by-default settlement intent after compliance and wallet checks", "security": [{ "adminBearer": [] }], "responses": { "201": { "description": "Settlement intent created" }, "409": { "description": "Compliance or wallet gate failed" } } }
    },
    "/api/admin/settlement-intents/{intentId}/status": {
      "patch": { "summary": "Update a settlement intent status; confirmed requires tx hash", "security": [{ "adminBearer": [] }], "responses": { "200": { "description": "Settlement intent status updated" } } }
    },
    "/api/admin/dataroom/access": {
      "post": { "summary": "Grant or revoke partner/project dataroom access", "security": [{ "adminBearer": [] }], "responses": { "200": { "description": "Access updated" } } }
    },
    "/api/admin/dataroom/documents/{documentId}": {
      "patch": { "summary": "Update dataroom document metadata and storage URI", "security": [{ "adminBearer": [] }], "responses": { "200": { "description": "Document metadata updated" } } }
    },
    "/api/admin/admin-notes": {
      "post": { "summary": "Add private admin note", "security": [{ "adminBearer": [] }], "responses": { "201": { "description": "Private note created" } } }
    }
  },
  "components": {
    "securitySchemes": {
      "adminBearer": { "type": "http", "scheme": "bearer" }
    }
  }
}
