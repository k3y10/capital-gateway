# Public chain configuration
VITE_CHAIN_ID=8453
VITE_USDC_CONTRACT_ADDRESS=
VITE_WALLETCONNECT_PROJECT_ID=

# Frontend API config. Leave empty when the Vite dev server proxies /api.
VITE_CAPITAL_API_BASE_URL=

# Local-only convenience tokens. Do not expose admin or partner portal tokens in browser envs in production.
VITE_CAPITAL_ADMIN_API_TOKEN=
VITE_CAPITAL_PARTNER_PORTAL_TOKEN=
VITE_CAPITAL_PARTNER_CODE=WOLFDEN-ALPHA

# API runtime
NODE_ENV=development
DATABASE_URL=postgres://mindlaunch:mindlaunch@localhost:5432/mindlaunch
DATABASE_SSL=false
DATABASE_POOL_MAX=10
CAPITAL_API_PORT=8787
CAPITAL_API_PROXY_TARGET=http://127.0.0.1:8787
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://mindlaunch.xyz

# Generate a long random value for production, for example:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
CAPITAL_ADMIN_API_TOKEN=replace-with-a-long-random-admin-token-at-least-32-chars

# Partner portal tokens are hashed into partners.portal_token_hash during db:seed.
PARTNER_TOKEN_REQUIRED=true
PARTNER_TOKEN_WOLFDEN_ALPHA=
PARTNER_TOKEN_BASE_BUILD=
PARTNER_TOKEN_FIELD_OPS=
