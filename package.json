{
  "name": "mindlaunch-capital-gateway",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api:dev": "node --watch api/server.mjs",
    "api:start": "node api/server.mjs",
    "db:migrate": "node api/migrate.mjs",
    "db:seed": "node api/seed.mjs",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prod:check": "pnpm run prisma:validate && pnpm run typecheck && pnpm run lint && pnpm run build",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@vitejs/plugin-react": "latest",
    "dotenv": "^17.4.2",
    "lucide-react": "latest",
    "pg": "^8.22.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "vite": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "playwright": "^1.61.0",
    "prisma": "^7.8.0",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
